
{
  "buildCommand": "npm run build -- --mode node",
  "outputDirectory": "dist/client",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/[[...routes]]"
    }
  ],
  "functions": {
    "api/[[...routes]].js": {
      "memory": 3008,
      "maxDuration": 60
    }
  }
}
